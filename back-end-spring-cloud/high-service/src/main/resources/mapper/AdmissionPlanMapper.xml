<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.highservice.mapper.volunteer.AdmissionPlanMapper">

    <select id="getAdmissionHistory" resultType="org.example.highservice.entity.volunteer.AdmissionPlan">
        SELECT * FROM admission_plan
        <where>
            <if test="majorId != null">
                AND major_id = #{majorId}
            </if>
            <if test="universityId != null">
                AND university_id = #{universityId}
            </if>
            <if test="year != null">
                AND year = #{year}
            </if>
        </where>
        ORDER BY year DESC
    </select>
    <select id="getLatestAdmission" resultType="org.example.highservice.entity.volunteer.AdmissionPlan">
        SELECT * FROM admission_plan
        WHERE major_id = #{majorId}
          AND university_id = #{universityId}
        ORDER BY year DESC
            LIMIT 1
    </select>

</mapper>